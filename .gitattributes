# Normalize line endings to LF in the repo; check out as CRLF on Windows
* text=auto eol=lf

# Force LF for these types regardless of OS
*.cs     text eol=lf
*.csproj text eol=lf
*.slnx   text eol=lf
*.sln    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.ps1    text eol=lf
*.props  text eol=lf
*.targets text eol=lf

# Binaries — do not mangle
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.dll    binary
*.exe    binary
*.nupkg  binary
