<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  hive-site.xml — Hive client/server configuration that delegates
  all metastore operations to the Hmsnet.Metastore service
  running on the Docker host at port 9083.
-->
<configuration>

  <!-- ── Metastore connection ─────────────────────────────────────── -->
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://host.docker.internal:9083</value>
    <description>
      Thrift URI of the remote Hive Metastore service.
      'host.docker.internal' resolves to the Docker host on
      Docker Desktop (Windows/Mac) and with extra_hosts on Linux.
    </description>
  </property>

  <!-- ── HiveServer2 ──────────────────────────────────────────────── -->
  <property>
    <name>hive.server2.thrift.port</name>
    <value>10000</value>
  </property>

  <property>
    <name>hive.server2.thrift.bind.host</name>
    <value>0.0.0.0</value>
  </property>

  <!-- Allow passwordless connections for local testing -->
  <property>
    <name>hive.server2.authentication</name>
    <value>NONE</value>
  </property>

  <!-- Run queries as the hive user, not the connected user.
       Required when there is no HDFS/Kerberos. -->
  <property>
    <name>hive.server2.enable.doAs</name>
    <value>false</value>
  </property>

  <!-- ── Scratch / temp dirs — use local FS, no HDFS needed ──────── -->
  <property>
    <name>hive.exec.scratchdir</name>
    <value>/tmp/hive-scratch</value>
  </property>

  <property>
    <name>hive.exec.local.scratchdir</name>
    <value>/tmp/hive-local-scratch</value>
  </property>

  <property>
    <name>hive.downloaded.resources.dir</name>
    <value>/tmp/hive-resources</value>
  </property>

  <!-- Disable HDFS permission check on scratch dir -->
  <property>
    <name>hive.scratch.dir.permission</name>
    <value>733</value>
  </property>

  <!-- ── Warehouse ────────────────────────────────────────────────── -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>/user/hive/warehouse</value>
  </property>

  <!-- ── Timeouts / retries ───────────────────────────────────────── -->
  <property>
    <name>hive.metastore.client.socket.timeout</name>
    <value>300</value>
  </property>

  <property>
    <name>hive.metastore.connect.retries</name>
    <value>5</value>
  </property>

  <property>
    <name>hive.metastore.failure.retries</name>
    <value>3</value>
  </property>

  <!-- Disable materialized view cache and notification polling (requires
       HMS APIs our metastore doesn't serve) -->
  <property>
    <name>hive.server2.materializedviews.registry.impl</name>
    <value>DUMMY</value>
  </property>

  <property>
    <name>hive.notification.event.poll.interval</name>
    <value>-1</value>
  </property>

  <!-- ── Disable schema validation (our metastore manages schema) ─── -->
  <property>
    <name>datanucleus.schema.autoCreateAll</name>
    <value>false</value>
  </property>

  <property>
    <name>hive.metastore.schema.verification</name>
    <value>false</value>
  </property>

</configuration>
